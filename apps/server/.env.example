#Required
DB_URL=mongodb://localhost:27017/neurovault
ADMIN_SECRET=change-me
REDIS_URL=redis://localhost:6379

# Embeddings — Jina AI (https://jina.ai)
JINA_API_KEY=

PORT=3001
CORS_ORIGIN=http://localhost:3000
UPLOAD_DIR=uploads

#LLM provider — Ollama Cloud (OpenAI-compatible)
# Model list: https://ollama.com/search
LLM_PROVIDER=openai-compatible
LLM_MODEL=gemma3:12b-cloud
LLM_BASE_URL=https://ollama.com/v1
# API key from https://ollama.com account settings
LLM_API_KEY=
# Gemini (only needed if using LLM_PROVIDER=gemini)
GEMINI_API_KEY=

#Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

#Qdrant
# Default: localhost:6333 — override in code if you run Qdrant on a different host/port

#Sync / Vaults
VAULTS_PATH=data/vaults

#Email ingest
EMAIL_WEBHOOK_SECRET=
# Comma-separated list of allowed sender addresses
EMAIL_ALLOWLIST=

# Graph tuning (optional)
# GRAPH_SIMILARITY_THRESHOLD=0.7
# GRAPH_MAX_SIMILAR_PER_FILE=5
# GRAPH_CHUNKS_NEIGHBORS=10
