{
  "name": "neurovault",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "optionalDependencies": {
    "@esbuild/win32-x64": "0.25.9"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "esbuild": "^0.28.0"
  },
  "lint-staged": {
    "*.{ts,tsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
